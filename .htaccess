# Deny all direct web access to the project root.
# This is a safety net for shared hosting where the project
# may accidentally be placed inside a web-accessible directory.
# Only the public/ folder should be served by the web server.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # If someone accesses this directory directly, deny everything
    # except the public/ subdirectory
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Block access to sensitive files if this directory is ever web-accessible
<FilesMatch "^\.env|\.env\..*|composer\.json|composer\.lock|package\.json|artisan$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Block access to sensitive directories
<IfModule mod_rewrite.c>
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/|$) - [F,L]
</IfModule>
